[
  {
    "name": "Calendar only (canary, no modules)",
    "import": {
      "./dist/index.mjs": "{ Calendar }"
    },
    "limit": "18 KB",
    "ignore": ["react", "react-dom"]
  },
  {
    "name": "Calendar + Days only (minimal viable)",
    "import": {
      "./dist/index.mjs": "{ Calendar }",
      "./dist/modules/days.mjs": "{ CalendarDays }"
    },
    "limit": "21.5 KB",
    "ignore": ["react", "react-dom"]
  },
  {
    "name": "Calendar + Toolbar + Days",
    "import": {
      "./dist/index.mjs": "{ Calendar }",
      "./dist/modules/toolbar.mjs": "{ CalendarToolbar, CalendarToolbarPrev, CalendarToolbarNext, CalendarToolbarMonthTrigger, CalendarToolbarYearTrigger, CalendarToolbarGroup }",
      "./dist/modules/days.mjs": "{ CalendarDays }"
    },
    "limit": "26 KB",
    "ignore": ["react", "react-dom"]
  },
  {
    "name": "Calendar + Days + Dracula theme + Compact appearance",
    "import": {
      "./dist/index.mjs": "{ Calendar }",
      "./dist/modules/days.mjs": "{ CalendarDays }",
      "./dist/themes.mjs": "{ dracula }",
      "./dist/appearances.mjs": "{ compact }"
    },
    "limit": "25.5 KB",
    "ignore": ["react", "react-dom"]
  },
  {
    "name": "Prebuilt SimpleCalendar (one import)",
    "import": {
      "./dist/prebuilt.mjs": "{ SimpleCalendar }"
    },
    "limit": "27 KB",
    "ignore": ["react", "react-dom"]
  }
]
