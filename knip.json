{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/react/index.ts",
    "src/react/context.ts",
    "src/react/prebuilt.tsx",
    "src/modules/index.ts",
    "src/modules/*/Calendar*.tsx",
