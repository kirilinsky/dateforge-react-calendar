{
  "name": "react-calendar-datetime",
  "version": "6.0.0-beta.1",
  "description": "Zero-dependency React datepicker and time picker. Supports date range, multi-select, themes, gestures and responsive layout.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./themes": {
      "default": "./dist/themes/index.css"
    },
    "./themes/*": {
      "default": "./dist/themes/*.css"
    },
    "./appearances": {
      "default": "./dist/appearances/index.css"
    },
    "./appearances/*": {
      "default": "./dist/appearances/*.css"
    },
    "./style.css": {
      "default": "./dist/style.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/react-calendar-datetime"
  },
  "homepage": "https://calendar-demo-pi.vercel.app/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsdown --watch",
    "build": "tsdown --dts && npx tsx scripts/generate-theme.ts && npx tsx scripts/generate-appearance.ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tsdown/css": "^0.21.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "calendar",
    "datepicker",
    "date picker",
    "time picker",
    "datetime-picker",
    "date range picker",
    "range picker",
    "multi select",
    "date-range",
    "typescript",
    "a11y",
    "i18n",
    "accessibility",
    "lightweight",
    "localization",
    "headless",
    "mobile",
    "customizable"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT"
}