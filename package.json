{
  "name": "react-calendar-datetime",
  "version": "6.0.0-beta.14",
  "description": "Zero-dependency React datepicker and time picker. Supports date range, multi-select, themes, gestures and responsive layout.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./context": {
      "types":   "./dist/context.d.ts",
      "import":  "./dist/context.mjs",
      "require": "./dist/context.cjs"
    },
    "./modules": {
      "types":   "./dist/modules/index.d.ts",
      "import":  "./dist/modules/index.mjs",
      "require": "./dist/modules/index.cjs"
    },
    "./modules/days": {
      "types":   "./dist/modules/days.d.ts",
      "import":  "./dist/modules/days.mjs",
      "require": "./dist/modules/days.cjs"
    },
    "./modules/nav": {
      "types":   "./dist/modules/nav.d.ts",
      "import":  "./dist/modules/nav.mjs",
      "require": "./dist/modules/nav.cjs"
    },
    "./modules/months": {
      "types":   "./dist/modules/months.d.ts",
      "import":  "./dist/modules/months.mjs",
      "require": "./dist/modules/months.cjs"
    },
    "./modules/time": {
      "types":   "./dist/modules/time.d.ts",
      "import":  "./dist/modules/time.mjs",
      "require": "./dist/modules/time.cjs"
    },
    "./modules/presets": {
      "types":   "./dist/modules/presets.d.ts",
      "import":  "./dist/modules/presets.mjs",
      "require": "./dist/modules/presets.cjs"
    },
    "./modules/selected-dates": {
      "types":   "./dist/modules/selected-dates.d.ts",
      "import":  "./dist/modules/selected-dates.mjs",
      "require": "./dist/modules/selected-dates.cjs"
    },
    "./modules/manual-select": {
      "types":   "./dist/modules/manual-select.d.ts",
      "import":  "./dist/modules/manual-select.mjs",
      "require": "./dist/modules/manual-select.cjs"
    },
    "./modules/years-track": {
      "types":   "./dist/modules/years-track.d.ts",
      "import":  "./dist/modules/years-track.mjs",
      "require": "./dist/modules/years-track.cjs"
    },
    "./modules/months-track": {
      "types":   "./dist/modules/months-track.d.ts",
      "import":  "./dist/modules/months-track.mjs",
      "require": "./dist/modules/months-track.cjs"
    },
    "./modules/days-track": {
      "types":   "./dist/modules/days-track.d.ts",
      "import":  "./dist/modules/days-track.mjs",
      "require": "./dist/modules/days-track.cjs"
    },
    "./modules/years-grid": {
      "types":   "./dist/modules/years-grid.d.ts",
      "import":  "./dist/modules/years-grid.mjs",
      "require": "./dist/modules/years-grid.cjs"
    },
    "./themes": {
      "import": "./dist/themes/index.mjs",
      "require": "./dist/themes/index.cjs",
      "types": "./dist/themes/index.d.ts",
      "default": "./dist/themes/index.css"
    },
    "./themes/*": {
      "types": "./dist/themes/index.d.ts",
      "default": "./dist/themes/*.css"
    },
    "./appearances": {
      "import": "./dist/appearances/index.mjs",
      "require": "./dist/appearances/index.cjs",
      "types": "./dist/appearances/index.d.ts",
      "default": "./dist/appearances/index.css"
    },
    "./appearances/*": {
      "types": "./dist/appearances/index.d.ts",
      "default": "./dist/appearances/*.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/react-calendar-datetime"
  },
  "homepage": "https://calendar-demo-pi.vercel.app/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsdown --watch",
    "build": "tsdown --dts && npx tsx scripts/generate-theme.ts && npx tsx scripts/generate-appearance.ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tsdown/css": "^0.21.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "calendar",
    "datepicker",
    "date picker",
    "time picker",
    "datetime-picker",
    "date range picker",
    "range picker",
    "multi select",
    "date-range",
    "typescript",
    "a11y",
    "i18n",
    "accessibility",
    "lightweight",
    "localization",
    "headless",
    "mobile",
    "customizable"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT"
}