  "homepage": "https://calendar-demo-pi.vercel.app/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsdown --watch",
    "knip": "knip",
    "build": "tsdown --dts && npx tsx scripts/generate-theme.ts && npx tsx scripts/generate-appearance.ts",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
