{
  "name": "react-calendar-datetime",
  "version": "5.2.2",
  "description": "Zero-dependency React date & time picker, range & multi-select, themes, gestures, fluid adaptive layout.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/react-calendar-datetime"
  },
  "homepage": "https://calendar-demo-pi.vercel.app/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsdown --watch",
    "build": "npx tsx scripts/generate-theme.ts && tsdown --dts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tsdown/css": "^0.21.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "var-th": "^0.1.7"
  },
  "keywords": [
    "react",
    "calendar",
    "datepicker",
    "datetime-picker",
    "time-picker",
    "date-range-picker",
    "react-calendar",
    "react-datepicker",
    "date-picker",
    "range-picker",
    "multi-select",
    "localization",
    "i18n",
    "themes",
    "dark-mode",
    "css-variables",
    "customizable",
    "lightweight",
    "zero-dependencies",
    "typescript",
    "nextjs",
    "gestures",
    "presets",
    "responsive"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT"
}