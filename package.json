    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "jest-axe": "^10.0.0",
    "knip": "^6.7.0",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "react",
    "calendar",
    "datepicker",
    "date picker",
    "time picker",
    "datetime-picker",
    "date range picker",
    "range picker",
    "multi select",
    "date-range",
    "typescript",
    "a11y",
    "i18n",
    "accessibility",
    "lightweight",
    "localization",
    "headless",
    "mobile",
    "customizable"
